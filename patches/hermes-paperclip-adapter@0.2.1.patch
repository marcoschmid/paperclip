+function base64UrlJson(obj) {
+    return Buffer.from(JSON.stringify(obj))
+        .toString("base64")
+        .replace(/=/g, "")
+        .replace(/\+/g, "-")
+        .replace(/\//g, "_");
+}
+function signAgentJwt(secret, payload) {
+    const header = { alg: "HS256", typ: "JWT" };
+    const message = `${base64UrlJson(header)}.${base64UrlJson(payload)}`;
+    const signature = crypto
+        .createHmac("sha256", secret)
+        .update(message)
+        .digest("base64")
+        .replace(/=/g, "")
+        .replace(/\+/g, "-")
+        .replace(/\//g, "_");
+    return `${message}.${signature}`;
+}
